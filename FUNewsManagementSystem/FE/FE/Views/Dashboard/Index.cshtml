@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var token = HttpContextAccessor.HttpContext.Session.GetString("AuthToken");
}


<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="text-center text-white">
        <div class="spinner-border spinner-border-lg" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-4 fs-5">Loading Dashboard...</p>
    </div>
</div>

<!-- Error State -->
<div id="errorState" class="alert alert-danger d-none m-4 shadow-sm" role="alert">
    <div class="d-flex align-items-center">
       
        <div>
            <strong>Error!</strong>
            <span id="errorMessage" class="d-block mt-1"></span>
        </div>
        <button class="btn btn-danger ms-auto" onclick="loadReport()">
          Retry
        </button>
    </div>
</div>

<div id="reportContent">
    <div class="container-fluid px-4 py-4">
        <!-- Page Header -->
        <div class="row align-items-center mb-5 g-3">
            <div class="col-12 col-lg-8">
                <h1 class="fw-bold mb-2">
                 
                    Dashboard Analytics
                </h1>
                <p class="text-muted fs-5">Real-time insights and statistics</p>
            </div>
            <div class="col-12 col-lg-4 text-lg-end">
                <button class="btn btn-outline-primary me-2" id="btnLoadAll">
                 All Time
                </button>
                <button class="btn btn-primary" id="btnLoadReport">
                   Refresh
                </button>
            </div>
        </div>

        <!-- Date Filter -->
        <div class=" mb-5 shadow-sm border-0">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">From Date</label>
                        <input type="date" class="form-control" id="fromDate">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">To Date</label>
                        <input type="date" class="form-control" id="toDate">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Export</label>
                        <select class="form-select" id="exportFormat">
                            <option value="excel">Excel (.xlsx)</option>
                            <option value="csv">CSV</option>
                            <option value="pdf">PDF</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-success w-100" id="btnExport">
                           Export
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="row g-4 mb-5" id="statsRow">
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card text-bg-success stat-card">
                 
                    <div class="card-body text-center">
                        <h6 class="fw-semibold text-white-50 mb-2">Active Articles</h6>
                        <h2 class="fw-bold text-white mb-1" id="totalActive">0</h2>
                        <small class="text-white-50">Published & Live</small>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card text-bg-danger stat-card">
                   
                    <div class="card-body text-center">
                        <h6 class="fw-semibold text-white-50 mb-2">Inactive Articles</h6>
                        <h2 class="fw-bold text-white mb-1" id="totalInactive">0</h2>
                        <small class="text-white-50">Draft & Archived</small>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card text-bg-primary stat-card">
                
                    <div class="card-body text-center">
                        <h6 class="fw-semibold text-white-50 mb-2">Total Articles</h6>
                        <h2 class="fw-bold text-white mb-1" id="totalAll">0</h2>
                        <small class="text-white-50">All Time</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">

            <!-- Status Chart -->
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3 bg-white">
                    <h6 class="text-uppercase fw-bold border-bottom pb-2 mb-3">
                        Status Overview
                    </h6>
                    <canvas id="statusChart"></canvas>
                </div>
            </div>

            <!-- Top Categories -->
            <div class="col-12 col-lg-6">
                <div class="border rounded p-3 bg-white">
                    <h6 class="text-uppercase fw-bold border-bottom pb-2 mb-3">
                        Popular Categories
                    </h6>
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Author Chart -->
        <div class="row g-3">
            <div class="col-12">
                <div class="border rounded p-3 bg-white">
                    <h6 class="text-uppercase fw-bold border-bottom pb-2 mb-3">
                        Author Statistics
                    </h6>
                    <canvas id="authorChart"></canvas>
                </div>
            </div>
        </div>


        <!-- Detailed Tables -->
        <div class="row g-4">
            <!-- By Category -->
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-light">
                        <h6 class="mb-0 fw-semibold">
                         By Category
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Category</th>
                                        <th class="text-center">Total</th>
                                        <th class="text-center">Active</th>
                                        <th class="text-center">Inactive</th>
                                    </tr>
                                </thead>
                                <tbody id="tblByCategory">
                                    <tr><td colspan="4" class="text-center text-muted py-4">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <!-- By Author -->
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-light">
                        <h6 class="mb-0 fw-semibold">
                           By Author
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Author</th>
                                        <th class="text-center">Total</th>
                                        <th class="text-center">Active</th>
                                        <th class="text-center">Inactive</th>
                                    </tr>
                                </thead>
                                <tbody id="tblByAuthor">
                                    <tr><td colspan="4" class="text-center text-muted py-4">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Summary -->
        <div class="row g-4 mt-4">
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-light">
                        <h6 class="mb-0 fw-semibold">
                          Status Summary
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Status</th>
                                        <th class="text-center">Count</th>
                                    </tr>
                                </thead>
                                <tbody id="tblByStatus">
                                    <tr><td colspan="2" class="text-center text-muted py-4">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const API_BASE_URL = 'https://localhost:7135/api';

        // Hàm lấy token từ localStorage (thay đổi nếu bạn lưu chỗ khác)
        function getToken() {
            return localStorage.getItem('access_token') ||
                   sessionStorage.getItem('access_token') ||
                   null;
        }

        // Hàm decode JWT (không verify signature, chỉ decode payload)
        function decodeToken(token) {
            try {
                const payload = token.split('.')[1];
                const base64 = payload.replace(/-/g, '+').replace(/_/g, '/');
                const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));
                return JSON.parse(jsonPayload);
            } catch (e) {
                console.error('Invalid token');
                return null;
            }
        }

        // Hàm check xem user có phải admin không
        function isAdmin() {
            const token = getToken();
            if (!token) return false;

            const payload = decodeToken(token);
            if (!payload) return false;

            // Cách 1: claim "role" là string
            if (payload.role === 'Admin' || payload.role === 'Administrator') {
                return true;
            }

            // Cách 2: claim "role" là array
            if (Array.isArray(payload.role) && payload.role.includes('Admin')) {
                return true;
            }

            // Cách 3: claim chuẩn ClaimTypes.Role (thường là string hoặc array)
            if (payload['http://schemas.microsoft.com/ws/2008/06/identity/claims/role']) {
                const roleClaim = payload['http://schemas.microsoft.com/ws/2008/06/identity/claims/role'];
                if (Array.isArray(roleClaim)) {
                    return roleClaim.includes('Admin');
                }
                return roleClaim === 'Admin';
            }

            // Cách 4: custom claim khác, ví dụ "roles"
            if (Array.isArray(payload.roles) && payload.roles.includes('Admin')) {
                return true;
            }

            return false;
        }

        // Kiểm tra ngay khi page load
        $(document).ready(function () {
            if (!isAdmin()) {
                // Ẩn toàn bộ nội dung report
                $('#reportContent').addClass('d-none');
                showErrorState('Bạn không có quyền truy cập trang này. Yêu cầu vai trò Admin.');
                $('#loadingOverlay').removeClass('show'); // ẩn loading nếu có
                return;
            }

            // Nếu là admin thì tiếp tục init bình thường
            hideErrorState();
            initCharts();
            // ... các hàm load data report khác
        });

        // Các hàm cũ của bạn giữ nguyên
        let currentReportData = null;
        let charts = { status: null, category: null, author: null };
        // ...
    </script>
    <script>
        const API_BASE_URL = 'https://localhost:7135/api';
        let currentReportData = null;
        let charts = { status: null, category: null, author: null };

        function showLoading(show) {
            $('#loadingOverlay').toggleClass('show', show);
        }

        function showErrorState(message) {
            $('#errorMessage').text(message);
            $('#errorState').removeClass('d-none');
            $('#reportContent').addClass('d-none');
        }

        function hideErrorState() {
            $('#errorState').addClass('d-none');
            $('#reportContent').removeClass('d-none');
        }

        function escapeHtml(text) {
            if (!text) return '';
            const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.toString().replace(/[&<>"']/g, m => map[m]);
        }

        function initCharts() {
            const commonOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } }
                },
                animation: { duration: 1200, easing: 'easeOutQuart' }
            };

            // Status Pie Chart
            charts.status = new Chart(document.getElementById('statusChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Active', 'Inactive'],
                    datasets: [{
                        data: [0, 0],
                        backgroundColor: ['#10b981', '#ef4444'],
                        borderWidth: 3,
                        borderColor: '#fff',
                        hoverBorderWidth: 4
                    }]
                },
                options: {
                    ...commonOptions,
                    cutout: '60%',
                    plugins: {
                        ...commonOptions.plugins,
                        tooltip: {
                            callbacks: {
                                label: ctx => `${ctx.label}: ${ctx.parsed.toLocaleString()} (${Math.round(ctx.parsed * 100 / ctx.dataset.total)}%)`
                            }
                        }
                    }
                }
            });

            // Category Bar Chart
            charts.category = new Chart(document.getElementById('categoryChart'), {
                type: 'bar',
                data: { labels: [], datasets: [{ label: 'Articles', data: [], backgroundColor: '#3b82f6', borderRadius: 8 }] },
                options: {
                    ...commonOptions,
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 } },
                        x: { ticks: { maxRotation: 45, minRotation: 45 } }
                    }
                }
            });

            // Author Horizontal Bar
            charts.author = new Chart(document.getElementById('authorChart'), {
                type: 'bar',
                data: {
                    labels: [],
                    datasets: [
                        { label: 'Active', data: [], backgroundColor: '#10b981', borderRadius: 8 },
                        { label: 'Inactive', data: [], backgroundColor: '#ef4444', borderRadius: 8 }
                    ]
                },
                options: {
                    ...commonOptions,
                    indexAxis: 'y',
                    scales: {
                        x: { beginAtZero: true, ticks: { stepSize: 1 } },
                        y: { ticks: { maxRotation: 0 } }
                    }
                }
            });
        }

        function updateCharts(data) {
            if (!data) return;

            // Status Chart
            charts.status.data.datasets[0].data = [data.totalActive || 0, data.totalInactive || 0];
            charts.status.update('active', { duration: 800 });

            // Category Chart (Top 10)
            if (data.byCategory?.length) {
                const top10 = data.byCategory.slice(0, 10);
                charts.category.data.labels = top10.map(item => item.groupByName || 'Unknown');
                charts.category.data.datasets[0].data = top10.map(item => item.totalArticles || 0);
                charts.category.update('active', { duration: 800 });
            }

            // Author Chart (Top 10)
            if (data.byAuthor?.length) {
                const top10 = data.byAuthor.slice(0, 10);
                charts.author.data.labels = top10.map(item => item.groupByName || 'Unknown');
                charts.author.data.datasets[0].data = top10.map(item => item.activeArticles || 0);
                charts.author.data.datasets[1].data = top10.map(item => item.inactiveArticles || 0);
                charts.author.update('active', { duration: 800 });
            }
        }

        $(document).ready(function() {
            // Set default 30 days
            const today = new Date(), last30 = new Date(today);
            last30.setDate(today.getDate() - 30);
            $('#toDate').val(today.toISOString().split('T')[0]);
            $('#fromDate').val(last30.toISOString().split('T')[0]);

            initCharts();
            loadReport();

            $('#btnLoadReport, #btnLoadAll').click(loadReport);
            $('#btnExport').click(exportToExcel);
        });

        async function loadReport() {
            hideErrorState();
            const fromDate = $('#fromDate').val(), toDate = $('#toDate').val();
            const token = '@token';

            if (!token) {
                showErrorState('Authentication token missing. Please log in again!');
                return;
            }

            let url = `${API_BASE_URL}/Report`;
            const params = [];
            // if (fromDate) params.push(`fromDate=${encodeURIComponent(fromDate)}`);
            // if (toDate) params.push(`toDate=${encodeURIComponent(toDate)}`);
            // if (params.length) url += '?' + params.join('&');

            showLoading(true);
            try {
                const response = await fetch(url, {
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Accept': 'application/json'
                    }
                });
                console.log("response report",response);

                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const data = await response.json();
                showLoading(false);
                currentReportData = data;
                renderReport(data);
                updateCharts(data);
            } catch (error) {
                showLoading(false);
                console.error('Report error:', error);
                showErrorState(`Failed to load dashboard: ${error.message}`);
            }
        }

        function renderReport(data) {
            $('#totalActive').text((data.totalActive || 0).toLocaleString());
            $('#totalInactive').text((data.totalInactive || 0).toLocaleString());
            $('#totalAll').text((data.totalAll || 0).toLocaleString());

            fillTable('#tblByCategory', data.byCategory || []);
            fillTable('#tblByAuthor', data.byAuthor || []);
            fillStatusTable('#tblByStatus', data.byStatus || []);
        }

        function fillTable(tableId, list) {
            const tbody = $(tableId);
            tbody.empty();
            if (!list.length) {
                tbody.html('<tr><td colspan="4" class="text-center text-muted py-4">No data available</td></tr>');
                return;
            }

            list.slice(0, 8).forEach(item => {
                tbody.append(`
                    <tr>
                        <td>
                          
                            ${escapeHtml(item.groupByName || 'Unknown')}
                        </td>
                        <td class="text-center fw-bold">${item.totalArticles?.toLocaleString() || 0}</td>
                        <td class="text-center"><span class="badge bg-success">${item.activeArticles || 0}</span></td>
                        <td class="text-center"><span class="badge bg-danger">${item.inactiveArticles || 0}</span></td>
                    </tr>
                `);
            });
        }

        function fillStatusTable(tableId, list) {
            const tbody = $(tableId);
            tbody.empty();
            if (!list.length) {
                tbody.html('<tr><td colspan="2" class="text-center text-muted py-4">No data available</td></tr>');
                return;
            }

            list.forEach(item => {
                const isActive = item.groupByName === 'Active';
                tbody.append(`
                    <tr>
                        <td>
                            <i class="bi ${isActive ? 'bi-check-circle-fill' : 'bi-x-circle-fill'} me-2 ${isActive ? 'text-success' : 'text-danger'}"></i>
                            ${isActive ? 'Active' : 'Inactive'}
                        </td>
                        <td class="text-center">
                            <span class="badge ${isActive ? 'bg-success' : 'bg-danger'} fs-6">${item.totalArticles?.toLocaleString() || 0}</span>
                        </td>
                    </tr>
                `);
            });
        }

        function exportToExcel() {
            if (!currentReportData) {
                Swal.fire({
                    icon: 'warning',
                    title: 'No Data',
                    text: 'Please load report data first!',
                    confirmButtonText: 'OK'
                });
                return;
            }

            Swal.fire({
                title: 'Exporting...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            setTimeout(() => {
                try {
                    const wb = XLSX.utils.book_new();

                    // Summary Sheet
                    const summary = [
                        ['DASHBOARD REPORT'],
                        [''],
                        ['Export Date:', new Date().toLocaleDateString()],
                        ['From:', $('#fromDate').val() || 'All Time'],
                        ['To:', $('#toDate').val() || 'All Time'],
                        [''],
                        ['SUMMARY'],
                        ['Metric', 'Count'],
                        ['Active Articles', currentReportData.totalActive || 0],
                        ['Inactive Articles', currentReportData.totalInactive || 0],
                        ['Total Articles', currentReportData.totalAll || 0]
                    ];
                    const ws1 = XLSX.utils.aoa_to_sheet(summary);
                    XLSX.utils.book_append_sheet(wb, ws1, 'Summary');

                    // Category Sheet
                    if (currentReportData.byCategory?.length) {
                        const catData = [['CATEGORY REPORT'], [''],
                            ['Category', 'Total', 'Active', 'Inactive'],
                            ...currentReportData.byCategory.map(i => [
                                i.groupByName || 'Unknown',
                                i.totalArticles || 0,
                                i.activeArticles || 0,
                                i.inactiveArticles || 0
                            ])
                        ];
                        const ws2 = XLSX.utils.aoa_to_sheet(catData);
                        XLSX.utils.book_append_sheet(wb, ws2, 'ByCategory');
                    }

                    const filename = `Dashboard_Report_${new Date().toISOString().slice(0,10)}.xlsx`;
                    XLSX.writeFile(wb, filename);

                    Swal.fire({
                        icon: 'success',
                        title: 'Exported!',
                        text: `Downloaded: ${filename}`,
                        timer: 2500,
                        showConfirmButton: false
                    });
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Export Failed',
                        text: error.message
                    });
                }
            }, 500);
        }
    </script>
    <style>
        canvas {
            max-width: 100%;
            height: 300px !important;
        }
    </style>

}