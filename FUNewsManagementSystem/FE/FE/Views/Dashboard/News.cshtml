@{
    ViewData["Title"] = "News Management";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">News Management</h2>
        <p class="text-muted mb-0">List of all news articles</p>
    </div>
    <div>
        <button class="btn btn-primary" onclick="openCreateModal()">
            Create New Article
        </button>
    </div>
</div>

<!-- Search and Filter -->
<div class=" mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text">
                        Search
                    </span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by title, author, category...">
                </div>
            </div>
            <div class="col-md-2">
                <select class="form-select" id="statusFilter">
                    <option value="">All Statuses</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" id="dateFrom" class="form-control" placeholder="From date">
            </div>
            <div class="col-md-2">
                <input type="date" id="dateTo" class="form-control" placeholder="To date">
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" id="btnRefresh">
                    Refresh
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Loading State -->
<div id="loadingState" class="text-center py-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p class="mt-3 text-muted">Loading data...</p>
</div>

<div id="errorState" class="alert alert-danger d-none" role="alert">
    <span id="errorMessage"></span>
    <button class="btn btn-sm btn-danger ms-3" onclick="loadNews()">
        Try Again
    </button>
</div>

<div id="emptyState" class="text-center py-5 d-none">
    <p class="mt-3 text-muted">No articles found</p>
</div>

<div id="newsContainer" class="row g-4 d-none">

</div>

<div id="paginationContainer" class="d-flex justify-content-center mt-4 d-none">
    <nav>
        <ul class="pagination" id="pagination">
           
        </ul>
    </nav>
</div>

<div class="modal fade" id="newsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-sm">

            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold" id="modalTitle">Article Editor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="newsForm">
                    <input type="hidden" id="newsId">

                    <!-- Article Title -->
                    <div class="mb-3">
                        <label for="newsTitle" class="form-label fw-semibold">Article Title <span class="text-danger">*</span></label>
                        <input type="text" id="newsTitle" class="form-control" placeholder="Enter article title" required>
                    </div>

                    <!-- Headline -->
                    <div class="mb-3">
                        <label for="headline" class="form-label fw-semibold">Short Headline</label>
                        <input type="text" id="headline" class="form-control" placeholder="Optional short headline">
                    </div>

                    <!-- Content -->
                    <div class="mb-3">
                        <label for="newsContent" class="form-label fw-semibold">Main Content <span class="text-danger">*</span></label>
                        <textarea id="newsContent" class="form-control" rows="5" placeholder="Write your article content..." required></textarea>
                    </div>

                    <!-- Source -->
                    <div class="mb-3">
                        <label for="newsSource" class="form-label fw-semibold">Reference Source</label>
                        <input type="text" id="newsSource" class="form-control" placeholder="Example: Website, book, N/A">
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label for="categoryId" class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                        <select id="categoryId" class="form-select" required>
                            <option value="">-- Choose Category --</option>
                        </select>
                    </div>

                    <!-- Tags + AI -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold d-flex align-items-center justify-content-between">
                            <span>Tag Selection</span>
                            <button type="button" class="btn btn-sm btn-outline-dark" id="btnAISuggest" onclick="getAISuggestions()">
                                <i class="bi bi-stars"></i> Auto Tag
                            </button>
                        </label>

                        <!-- AI Tag suggestion -->
                        <div id="aiSuggestionsContainer" class="d-none p-2 border rounded bg-light mb-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-bold small">AI Suggested Tags</span>
                                <small class="text-muted" id="aiModelUsed"></small>
                            </div>
                            <div id="aiSuggestedTags" class="d-flex flex-wrap gap-2 small"></div>
                        </div>

                        <select id="tagIds" class="form-select" multiple></select>
                        <small class="text-muted">Use Ctrl/Cmd to select multiple tags</small>
                    </div>

                    <!-- Status -->
                    <div class="mb-3">
                        <label for="newsStatus" class="form-label fw-semibold">Visibility</label>
                        <select id="newsStatus" class="form-select">
                            <option value="true">Published</option>
                            <option value="false">Draft</option>
                        </select>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
                <button class="btn btn-success" onclick="saveNews()">Save Article</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    Article Details
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="viewContent">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1;
        let totalCount = 0;
        const itemsPerPage = 9;
        let newsModal;
        let viewModal;
        let currentViewId = null;
        let allTags = [];

        $(document).ready(function() {
            newsModal = new bootstrap.Modal(document.getElementById('newsModal'));
            viewModal = new bootstrap.Modal(document.getElementById('viewModal'));
            loadNews();
            loadCategories();
            loadTags();

            $('#searchInput').on('input', debounce(function() {
                currentPage = 1;
                loadNews();
            }, 500));

            $('#statusFilter, #dateFrom, #dateTo').change(function() {
                currentPage = 1;
                loadNews();
            });

            $('#btnRefresh').click(function() {
                resetFilters();
                loadNews();
            });
        });

        function loadNews() {
            showLoading();
            hideError();

            const searchTerm = $('#searchInput').val().trim();
            const statusFilter = $('#statusFilter').val();
            const dateFrom = $('#dateFrom').val();
            const dateTo = $('#dateTo').val();

            const params = new URLSearchParams({
                page: currentPage,
                pageSize: itemsPerPage
            });

            if (searchTerm) params.append('search', searchTerm);
            if (statusFilter !== '') params.append('status', statusFilter);
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);

            $.ajax({
                url: `/News/GetNews?${params.toString()}`,
                method: "GET",
                success: function(response) {
                    console.log('API Response:', response);
                    hideLoading();

                    const newsData = response.value || [];
                    totalCount = response['@@odata.count'] || newsData.length;

                    if (newsData.length === 0) {
                        showEmptyState();
                    } else {
                        renderNews(newsData);
                    }
                },
                error: function(xhr) {
                    console.error('Load news error:', xhr);
                    hideLoading();
                    handleError(xhr);
                }
            });
        }

        function loadCategories() {
            $.ajax({
                url: '/News/GetCategories',
                method: "GET",
                success: function(response) {
                    const categories = response.value || response;
                    let options = '<option value="">Select category</option>';
                    categories.forEach(cat => {
                        options += `<option value="${cat.CategoryId}">${cat.CategoryName}</option>`;
                    });
                    $('#categoryId').html(options);
                }
            });
        }

        // Load Tags
        function loadTags() {
            $.ajax({
                url: '/News/GetTags',
                method: "GET",
                success: function(response) {
                    const tags = response.value || response;
                    allTags = tags; // Store for later use
                    let options = '';
                    tags.forEach(tag => {
                        options += `<option value="${tag.TagId}">${tag.TagName}</option>`;
                    });
                    $('#tagIds').html(options);
                }
            });
        }

        // AI Tag Suggestions
        async function getAISuggestions() {
            const title = $('#newsTitle').val().trim();
            const content = $('#newsContent').val().trim();

            if (!content && !title) {
                alert('Please enter a title or content for AI to suggest tags!');
                return;
            }

            const combinedContent = title + (title && content ? '\n\n' : '') + content;

            const btnAI = $('#btnAISuggest');
            const originalText = btnAI.html();
            btnAI.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Processing...');

            try {
                const response = await $.ajax({
                    url: 'https://localhost:7087/api/ai/suggesttags',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        content: combinedContent
                    })
                });

                console.log('AI Response:', response);
                displayAISuggestions(response.suggestedTags, response.modelUsed);

            } catch (error) {
                console.error('AI Suggestion Error:', error);
                alert('Unable to get AI suggestions. Please try again!');
            } finally {
                btnAI.prop('disabled', false).html(originalText);
            }
        }

        function displayAISuggestions(suggestedTags, modelUsed) {
            const container = $('#aiSuggestedTags');
            const aiContainer = $('#aiSuggestionsContainer');

            if (!suggestedTags || suggestedTags.length === 0) {
                aiContainer.addClass('d-none');
                return;
            }

            $('#aiModelUsed').text(`Model: ${modelUsed || 'AI'}`);

            let html = '';
            suggestedTags.forEach(tagName => {
                const matchedTag = allTags.find(t =>
                    t.TagName.toLowerCase() === tagName.toLowerCase() ||
                    t.TagName.toLowerCase().includes(tagName.toLowerCase()) ||
                    tagName.toLowerCase().includes(t.TagName.toLowerCase())
                );

                if (matchedTag) {
                    // Tag exists in database
                    html += `
                        <span class="badge bg-success ai-tag-badge"
                              data-tag-id="${matchedTag.TagId}"
                              onclick="selectAITag(this)"
                              style="cursor: pointer;">
                            ${matchedTag.TagName}
                        </span>
                    `;
                } else {
                    // Tag doesn't exist - show as suggestion only
                    html += `
                        <span class="badge bg-warning text-dark ai-tag-badge"
                              title="Tag not in system">
                            ${tagName}
                        </span>
                    `;
                }
            });

            container.html(html);
            aiContainer.removeClass('d-none');
        }

        function selectAITag(element) {
            const tagId = $(element).data('tag-id');
            const tagIds = $('#tagIds');

            // Get current selected values
            let selectedValues = tagIds.val() || [];

            // Toggle selection
            if (selectedValues.includes(tagId.toString())) {
                // Deselect
                selectedValues = selectedValues.filter(id => id !== tagId.toString());
                $(element).removeClass('bg-success').addClass('bg-secondary');
            } else {
                // Select
                selectedValues.push(tagId.toString());
                $(element).removeClass('bg-secondary').addClass('bg-success');
            }

            // Update select
            tagIds.val(selectedValues);
        }

        // Render News Cards
        function renderNews(newsData) {
            const container = $('#newsContainer');
            let html = '';

            newsData.forEach(news => {
                const id = news.NewsArticleId;
                const title = news.NewsTitle || 'No title';
                const headline = news.Headline || '';
                const content = news.NewsContent || 'No content';
                const excerpt = content.length > 150 ? content.substring(0, 150) + '...' : content;
                const createdDate = news.CreatedDate ? new Date(news.CreatedDate).toLocaleDateString('en-US') : 'N/A';
                const modifiedDate = news.ModifiedDate ? new Date(news.ModifiedDate).toLocaleDateString('en-US') : 'N/A';
                const newsStatus = news.NewsStatus;
                const categoryName = news.Category?.CategoryName || 'N/A';
                const authorName = news.CreatedBy?.AccountName || 'N/A';
                const tags = news.Tags || [];
                const statusBadge = getStatusBadge(newsStatus);

                let tagBadges = '';
                if (tags.length > 0) {
                    tags.slice(0, 3).forEach(tag => {
                        if (tag.tagName) {
                            tagBadges += `<span class="badge bg-info text-dark me-1">${tag.tagName}</span>`;
                        }
                    });
                    if (tags.length > 3) {
                        tagBadges += `<span class="badge bg-secondary">+${tags.length - 3}</span>`;
                    }
                }

                html += `
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 shadow-sm hover-card">
                            <div class="card-img-placeholder">
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0 flex-grow-1">${title}</h5>
                                    ${statusBadge}
                                </div>
                                ${headline ? `<p class="text-muted small fst-italic mb-2">${headline}</p>` : ''}
                                <p class="card-text text-muted small flex-grow-1">${excerpt}</p>
                                <div class="mb-2">
                                    <small class="text-muted">
                                        ${categoryName} | ${authorName}
                                    </small>
                                </div>
                                <div class="mb-2">${tagBadges}</div>
                                <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                    <div class="text-muted small">
                                        Created: ${createdDate}<br>
                                        Updated: ${modifiedDate}
                                    </div>
                                    <div class="btn-group" role="group">
                                        <button class="btn btn-sm btn-outline-primary" onclick="viewNews('${id}')" title="View details">
                                            View
                                        </button>
                                        <button class="btn btn-sm btn-outline-success" onclick="duplicateNews('${id}')" title="Duplicate">
                                            Duplicate
                                        </button>
                                        <button class="btn btn-sm btn-outline-warning" onclick="editNews('${id}')" title="Edit">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteNews('${id}')" title="Delete">
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });

            container.html(html);
            container.removeClass('d-none');
            $('#emptyState').addClass('d-none');
            renderPagination();
        }

        // Render Pagination
        function renderPagination() {
            const totalPages = Math.ceil(totalCount / itemsPerPage);
            if (totalPages <= 1) {
                $('#paginationContainer').addClass('d-none');
                return;
            }

            const pagination = $('#pagination');
            let html = `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="changePage(${currentPage - 1}); return false;">
                        Previous
                    </a>
                </li>
            `;

            for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    html += `
                        <li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>
                        </li>
                    `;
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }

            html += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link" href="#" onclick="changePage(${currentPage + 1}); return false;">
                        Next
                    </a>
                </li>
            `;

            pagination.html(html);
            $('#paginationContainer').removeClass('d-none');
        }

        function changePage(page) {
            const totalPages = Math.ceil(totalCount / itemsPerPage);
            if (page < 1 || page > totalPages) return;
            currentPage = page;
            loadNews();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function openCreateModal() {
            $('#modalTitle').text('Create New Article');
            $('#newsForm')[0].reset();
            $('#newsId').val('');
            $('#newsStatus').val('true');
            $('#aiSuggestionsContainer').addClass('d-none');
            newsModal.show();
        }

        // View News
        function viewNews(id) {
            currentViewId = id;
            $('#viewContent').html(`
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3 text-muted">Loading data...</p>
                </div>
            `);
            viewModal.show();

            $.ajax({
                url: `/News/GetNewsById?id=${id}`,
                method: "GET",
                success: function(response) {
                    const news = response.data;
                    renderViewModal(news);
                },
                error: function(xhr) {
                    $('#viewContent').html(`
                        <div class="alert alert-danger">
                            Unable to load article details!
                        </div>
                    `);
                }
            });
        }

        function renderViewModal(news) {
            const createdDate = news.createdDate ? new Date(news.createdDate).toLocaleString('en-US') : 'N/A';
            const modifiedDate = news.modifiedDate ? new Date(news.modifiedDate).toLocaleString('en-US') : 'N/A';
            const statusBadge = getStatusBadge(news.newsStatus);

            let tagBadges = '<span class="text-muted">None</span>';
            if (news.tags && news.tags.length > 0) {
                tagBadges = news.tags.map(tag =>
                    `<span class="badge bg-info text-dark me-1 mb-1">${tag.tagName}</span>`
                ).join('');
            }

            const html = `
                <div class="row">
                    <div class="col-12">
                        <div class="mb-4">
                            <h3 class="mb-3">${news.newsTitle}</h3>
                            ${news.headline ? `<h5 class="text-muted fst-italic mb-3">${news.headline}</h5>` : ''}
                            <div class="d-flex flex-wrap gap-3 mb-3">
                                <span>${statusBadge}</span>
                                <span id="categoryName" class="badge bg-primary">
                                    Category ID: ${news.categoryId}
                                </span>
                            </div>
                        </div>

                        <div class="card mb-3">
                            <div class="card-body">
                                <h6 class="card-title text-primary mb-3">
                                    Content
                                </h6>
                                <div class="content-text" style="white-space: pre-wrap; line-height: 1.8;">
                                    ${news.newsContent}
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h6 class="card-title text-primary mb-3">
                                            Other Information
                                        </h6>
                                        <table class="table table-sm table-borderless mb-0">
                                            <tr>
                                                <td class="text-muted" style="width: 40%;">
                                                    Source:
                                                </td>
                                                <td><strong>${news.newsSource || 'N/A'}</strong></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">
                                                    Created by:
                                                </td>
                                                <td><strong id="createdByName">User ID: ${news.createdById}</strong></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">
                                                    Updated by:
                                                </td>
                                                <td><strong id="updatedByName">${news.updatedById ? `User ID: ${news.updatedById}` : 'N/A'}</strong></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-body">
                                        <h6 class="card-title text-primary mb-3">
                                            Timestamps
                                        </h6>
                                        <table class="table table-sm table-borderless mb-0">
                                            <tr>
                                                <td class="text-muted" style="width: 40%;">
                                                    Created:
                                                </td>
                                                <td><strong>${createdDate}</strong></td>
                                            </tr>
                                            <tr>
                                                <td class="text-muted">
                                                    Updated:
                                                </td>
                                                <td><strong>${modifiedDate}</strong></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card">
                                    <div class="card-body">
                                        <h6 class="card-title text-primary mb-3">
                                            Tags
                                        </h6>
                                        <div>${tagBadges}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            $('#viewContent').html(html);

            // Load category name
            $.ajax({
                url: `/News/GetCategoryById?id=${news.categoryId}`,
                method: 'GET',
                success: function (res) {
                    const cat = res.data;
                    $('#categoryName').html(`${cat.categoryName}`);
                },
                error: function () {
                    $('#categoryName').html(`Category not found`);
                }
            });

            // Load creator name
            if (news.createdById) {
                $.ajax({
                    url: `/News/GetAccountById?id=${news.createdById}`,
                    method: 'GET',
                    success: function (res) {
                        const user = res.data;
                        $('#createdByName').text(user.accountName);
                    },
                    error: function () {
                        $('#createdByName').text('Unknown');
                    }
                });
            }

            // Load updater name
            if (news.updatedById) {
                $.ajax({
                    url: `/News/GetAccountById?id=${news.updatedById}`,
                    method: 'GET',
                    success: function (res) {
                        const user = res.data;
                        $('#updatedByName').text(user.accountName);
                    },
                    error: function () {
                        $('#updatedByName').text('Unknown');
                    }
                });
            }
        }

        // Edit News
        function editNews(id) {
            $.ajax({
                url: `/News/GetNewsById?id=${id}`,
                method: "GET",
                success: function(response) {
                    const news = response.data;
                    $('#modalTitle').text('Edit Article');
                    $('#newsId').val(news.newsArticleId);
                    $('#newsTitle').val(news.newsTitle);
                    $('#headline').val(news.headline || '');
                    $('#newsContent').val(news.newsContent);
                    $('#newsSource').val(news.newsSource || '');
                    $('#categoryId').val(news.categoryId);
                    $('#newsStatus').val(news.newsStatus.toString());

                    const selectedTagIds = news.tags?.map(tag => tag.tagId.toString()) || [];
                    $('#tagIds').val(selectedTagIds);

                    // Hide AI suggestions when editing
                    $('#aiSuggestionsContainer').addClass('d-none');

                    newsModal.show();
                },
                error: function(xhr) {
                    alert('Unable to load article details!');
                }
            });
        }

        // Duplicate News
        function duplicateNews(id) {
            if (!confirm('Are you sure you want to duplicate this article?')) return;

            $.ajax({
                url: `/News/GetNewsById?id=${id}`,
                method: "GET",
                success: function(response) {
                    const news = response.data;
                    const duplicateData = {
                        newsTitle: news.newsTitle + ' (Copy)',
                        headline: news.headline,
                        newsContent: news.newsContent,
                        newsSource: news.newsSource,
                        categoryId: news.categoryId,
                        newsStatus: news.newsStatus,
                        tags: news.tags || []
                    };

                    $.ajax({
                        url: '/News/CreateNews',
                        method: "POST",
                        contentType: 'application/json',
                        data: JSON.stringify(duplicateData),
                        success: function() {
                            alert('Article duplicated successfully!');
                            loadNews();
                        },
                        error: function(xhr) {
                            console.error('Duplicate error:', xhr);
                            alert('Unable to duplicate article!');
                        }
                    });
                },
                error: function(xhr) {
                    alert('Unable to load article details!');
                }
            });
        }

        // Save News
        function saveNews() {
            if (!$('#newsForm')[0].checkValidity()) {
                $('#newsForm')[0].reportValidity();
                return;
            }

            const newsId = $('#newsId').val();
            const isEdit = newsId !== '';
            const selectedTagIds = $('#tagIds').val() || [];

            const tagsArray = selectedTagIds.map(tagId => {
                const tagOption = $(`#tagIds option[value="${tagId}"]`);
                return {
                    tagId: parseInt(tagId),
                    tagName: tagOption.text(),
                    note: null
                };
            });

            const newsData = {
                newsTitle: $('#newsTitle').val(),
                headline: $('#headline').val() || null,
                createdDate: null,
                newsContent: $('#newsContent').val(),
                newsSource: $('#newsSource').val() || 'N/A',
                categoryId: parseInt($('#categoryId').val()),
                newsStatus: $('#newsStatus').val() === 'true',
                createdById: null,
                updatedById: null,
                modifiedDate: null,
                tags: tagsArray
            };

            const url = isEdit ? `/News/UpdateNews?id=${newsId}` : '/News/CreateNews';
            const method = isEdit ? "PUT" : "POST";

            $.ajax({
                url: url,
                method: method,
                contentType: 'application/json',
                data: JSON.stringify(newsData),
                success: function() {
                    alert(isEdit ? 'Article updated successfully!' : 'New article created successfully!');
                    newsModal.hide();
                    loadNews();
                },
                error: function(xhr) {
                    console.error('Save error:', xhr);
                    alert('Unable to save article!');
                }
            });
        }

        // Delete News
        function deleteNews(id) {
            if (!confirm('Are you sure you want to delete this article?')) return;

            $.ajax({
                url: `/News/DeleteNews?id=${id}`,
                method: "DELETE",
                success: function() {
                    alert('Article deleted successfully!');
                    loadNews();
                },
                error: function(xhr) {
                    console.error('Delete error:', xhr);
                    alert('Unable to delete article!');
                }
            });
        }

        function resetFilters() {
            $('#searchInput').val('');
            $('#statusFilter').val('');
            $('#dateFrom').val('');
            $('#dateTo').val('');
            currentPage = 1;
        }

        function getStatusBadge(status) {
            return status
                ? '<span class="badge bg-success">Active</span>'
                : '<span class="badge bg-secondary">Inactive</span>';
        }

        function showLoading() {
            $('#loadingState').removeClass('d-none');
            $('#newsContainer').addClass('d-none');
            $('#emptyState').addClass('d-none');
            $('#paginationContainer').addClass('d-none');
        }

        function hideLoading() {
            $('#loadingState').addClass('d-none');
        }

        function showError(message) {
            $('#errorMessage').text(message);
            $('#errorState').removeClass('d-none');
        }

        function hideError() {
            $('#errorState').addClass('d-none');
        }

        function showEmptyState() {
            $('#newsContainer').addClass('d-none');
            $('#emptyState').removeClass('d-none');
            $('#paginationContainer').addClass('d-none');
        }

        function handleError(xhr) {
            let errorMsg = "Unable to load article list!";

            if (xhr.status === 401) {
                errorMsg = "Session expired. Please log in again!";
                setTimeout(() => {
                    window.location.href = '/Auth/Index';
                }, 2000);
            } else if (xhr.status === 403) {
                errorMsg = "You do not have access permission!";
            } else if (xhr.status === 0) {
                errorMsg = "Unable to connect to server!";
            } else if (xhr.responseJSON?.message) {
                errorMsg = xhr.responseJSON.message;
            }

            showError(errorMsg);
        }

        function debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                const later = () => {
                    clearTimeout(timeout);
                    func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        }
    </script>
    

}